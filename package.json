		"test:ui": "vitest --ui",
		"prepare": "husky"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-query": "^5.100.10",
		"@vercel/speed-insights": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"hotkeys-js": "^4.0.4",
		"lightningcss": "^1.32.0",
		"lucide-react": "^1.16.0",
		"motion": "^12.38.0",
		"next": "16.2.6",
		"next-intl": "^4.12.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hook-form": "^7.76.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"usehooks-ts": "^3.1.1",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
