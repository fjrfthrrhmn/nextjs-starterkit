{
	"name": "next-app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"check-types": "tsc --noEmit",
		"format": "prettier --check .",
